<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>This is a title</title>
</head>
<body>
    {{template "nav.gohtml"}}
    <div class="content">
        <h1>{{.Project.Title}}</h1>
        <p>{{.Project.Summary}}</p>

        <h2>Learning Outcomes</h2>
        {{.Project.ProjectOutcomes}}

        <h2>Project Outcomes</h2>
        {{.Project.ProjectOutcomes}}

        <h2>Project Images</h2>
        {{range $v := .Project.Images}}
        <img src="images/{{$.Project.FolderPathLowerCase}}/{{$v}}"/>
        {{end}}
    </div>
</body>
</html>